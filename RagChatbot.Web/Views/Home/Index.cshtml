@model IEnumerable<RagChatbot.Web.Models.Entities.Subject>
@{
    ViewData["Title"] = "Chat";
}

<div class="flex h-full bg-gray-50">
    <!-- Sidebar -->
    <div class="w-64 bg-white border-r flex flex-col">
        <div class="p-4 border-b">
            <h2 class="text-lg font-semibold text-gray-800">Subjects</h2>
        </div>
        <div class="flex-1 overflow-y-auto">
            <ul class="space-y-1 p-2">
                @foreach(var subject in Model)
                {
                    <li>
                        <button onclick="selectSubject(@subject.Id, '@subject.Name')" class="w-full text-left px-3 py-2 text-sm text-gray-700 rounded hover:bg-indigo-50 hover:text-indigo-600 focus:bg-indigo-100 focus:text-indigo-700 transition">
                            <i class="fa-solid fa-book mr-2"></i> @subject.Name
                        </button>
                    </li>
                }
            </ul>
        </div>
    </div>

    <!-- Main Chat Area -->
    <div class="flex-1 flex flex-col relative">
        <!-- Header -->
        <div class="p-4 border-b bg-white flex justify-between items-center shadow-sm z-10">
            <h2 class="text-lg font-semibold text-gray-800" id="currentSubjectTitle">Select a subject to start</h2>
            <div class="text-sm text-gray-500">
                <span id="connectionStatus" class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-red-100 text-red-800">
                    Disconnected
                </span>
            </div>
        </div>

        <!-- Chat Messages -->
        <div id="chatMessages" class="flex-1 overflow-y-auto p-4 space-y-6 bg-gray-50">
            <!-- Initial prompt -->
            <div class="flex justify-center my-4">
                <div class="bg-indigo-100 text-indigo-800 text-xs px-3 py-1 rounded-full">
                    Chat with your study documents
                </div>
            </div>
        </div>

        <!-- Input Area -->
        <div class="p-4 bg-white border-t">
            <form id="chatForm" class="max-w-4xl mx-auto flex items-end gap-2">
                <input type="hidden" id="currentSubjectId" value="" />
                <input type="hidden" id="currentSessionId" value="" />
                
                <div class="flex-1 bg-gray-100 rounded-lg border border-gray-300 focus-within:border-indigo-500 focus-within:ring-1 focus-within:ring-indigo-500 transition shadow-inner">
                    <textarea id="messageInput" rows="1" class="w-full bg-transparent border-0 focus:ring-0 resize-none p-3 block" placeholder="Ask a question about the documents... (Select a subject first)" disabled></textarea>
                </div>
                
                <button type="submit" id="sendBtn" class="bg-indigo-600 hover:bg-indigo-700 text-white p-3 rounded-lg shadow disabled:opacity-50 transition" disabled>
                    <i class="fa-solid fa-paper-plane"></i>
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let currentSubjectId = null;
        let currentSessionId = "";
        let isReceivingStream = false;
        let currentAssistantMessageDiv = null;
        let currentAssistantMarkdown = "";
        let isAiThinking = false;
        
        function showThinkingIndicator() {
            const chatMessages = document.getElementById("chatMessages");
            
            // Create unified AI bubble
            const msgWrapper = document.createElement("div");
            msgWrapper.className = "flex items-start gap-4";
            
            const avatar = document.createElement("div");
            avatar.className = "w-8 h-8 rounded bg-indigo-600 flex items-center justify-center text-white flex-shrink-0 mt-1 shadow-sm";
            avatar.innerHTML = '<i class="fa-solid fa-robot text-xs"></i>';
            
            const contentWrapper = document.createElement("div");
            contentWrapper.className = "flex-1 bg-white rounded-lg p-4 shadow-sm border border-indigo-100 text-gray-800 prose prose-indigo max-w-none relative transition-all duration-300";
            
            const thinkingContent = document.createElement("div");
            thinkingContent.id = "thinking-content";
            thinkingContent.className = "flex items-center gap-2 text-gray-500";
            
            const text = document.createElement("span");
            text.className = "text-sm font-medium italic";
            text.innerText = "AI đang suy nghĩ";
            
            const typing = document.createElement("span");
            typing.className = "animate-pulse flex space-x-1 mt-1";
            typing.innerHTML = '<div class="w-1.5 h-1.5 bg-indigo-400 rounded-full"></div><div class="w-1.5 h-1.5 bg-indigo-400 rounded-full" style="animation-delay: 0.2s"></div><div class="w-1.5 h-1.5 bg-indigo-400 rounded-full" style="animation-delay: 0.4s"></div>';
            
            thinkingContent.appendChild(text);
            thinkingContent.appendChild(typing);
            contentWrapper.appendChild(thinkingContent);
            
            msgWrapper.appendChild(avatar);
            msgWrapper.appendChild(contentWrapper);
            
            chatMessages.appendChild(msgWrapper);
            chatMessages.scrollTop = chatMessages.scrollHeight;
            
            // Track state
            currentAssistantMessageDiv = contentWrapper;
            isAiThinking = true;
            isReceivingStream = false;
            currentAssistantMarkdown = "";
        }

        function removeThinkingIndicator() {
            // Function no longer removes the bubble, just clears the thinking content inside it
            if (isAiThinking && currentAssistantMessageDiv) {
                const thinkingContent = document.getElementById("thinking-content");
                if (thinkingContent) {
                    thinkingContent.remove();
                }
                isAiThinking = false;
            }
        }
        
        // Setup SignalR connection
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/chatHub")
            .configureLogging(signalR.LogLevel.Information)
            .build();

        async function startConnection() {
            try {
                if (connection.state === signalR.HubConnectionState.Connected) return;
                await connection.start();
                console.log("SignalR Connected.");
                document.getElementById("connectionStatus").className = "inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-green-100 text-green-800";
                document.getElementById("connectionStatus").innerText = "Connected";
                
                // If a subject is selected and we reconnected, reload history
                if (currentSubjectId) {
                    try {
                        await connection.invoke("LoadSubjectHistory", currentSubjectId);
                    } catch (e) {
                        console.error("Error reloading history:", e);
                    }
                }
            } catch (err) {
                console.error(err);
                setTimeout(startConnection, 5000);
            }
        }

        connection.onclose(async () => {
            document.getElementById("connectionStatus").className = "inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-red-100 text-red-800";
            document.getElementById("connectionStatus").innerText = "Disconnected";
            await startConnection();
        });

        startConnection();

        function selectSubject(id, name) {
            currentSubjectId = id;
            currentSessionId = ""; // Reset session when changing subject
            document.getElementById("currentSubjectTitle").innerText = name;
            document.getElementById("messageInput").disabled = false;
            document.getElementById("sendBtn").disabled = false;
            document.getElementById("messageInput").placeholder = "Ask a question about " + name + "...";
            document.getElementById("messageInput").focus();
            
            // Show loading
            document.getElementById("chatMessages").innerHTML = `
                <div class="flex justify-center my-4">
                    <div class="bg-indigo-100 text-indigo-800 text-xs px-3 py-1 rounded-full animate-pulse">
                        Đang tải lịch sử chat...
                    </div>
                </div>
            `;
            
            // Load history
            try {
                if (connection.state === signalR.HubConnectionState.Connected) {
                    connection.invoke("LoadSubjectHistory", id).catch(err => {
                        console.error("Error invoking LoadSubjectHistory:", err);
                        document.getElementById("chatMessages").innerHTML = `<div class="text-red-500 text-center my-4">Lỗi tải lịch sử: ${err}</div>`;
                    });
                } else {
                    console.warn("Connection not ready, history will load when connected.");
                }
            } catch (err) {
                console.error("Error invoking LoadSubjectHistory:", err);
            }
        }

        connection.on("SessionCreated", (sessionId) => {
            currentSessionId = sessionId;
            console.log("Session created: " + sessionId);
        });

        connection.on("SessionLoaded", (sessionId, messages) => {
            currentSessionId = sessionId;
            const chatMessages = document.getElementById("chatMessages");
            chatMessages.innerHTML = "";
            
            if (!messages || messages.length === 0) {
                chatMessages.innerHTML = `
                    <div class="flex justify-center my-4">
                        <div class="bg-indigo-100 text-indigo-800 text-xs px-3 py-1 rounded-full">
                            Bắt đầu phiên chat mới
                        </div>
                    </div>
                `;
                return;
            }
            
            messages.forEach(msg => {
                const msgWrapper = document.createElement("div");
                
                if (msg.role === "user") {
                    msgWrapper.className = "flex flex-row-reverse items-start gap-4 mb-6";
                    const avatar = document.createElement("div");
                    avatar.className = "w-8 h-8 rounded bg-gray-200 flex items-center justify-center text-gray-600 flex-shrink-0 mt-1";
                    avatar.innerHTML = '<i class="fa-solid fa-user text-xs"></i>';
                    
                    const contentWrapper = document.createElement("div");
                    contentWrapper.className = "bg-indigo-600 text-white rounded-lg py-2 px-4 shadow max-w-[80%]";
                    contentWrapper.innerText = msg.content;
                    
                    msgWrapper.appendChild(avatar);
                    msgWrapper.appendChild(contentWrapper);
                } else if (msg.role === "assistant") {
                    msgWrapper.className = "flex items-start gap-4 mb-6";
                    const avatar = document.createElement("div");
                    avatar.className = "w-8 h-8 rounded bg-indigo-600 flex items-center justify-center text-white flex-shrink-0 mt-1 shadow-sm";
                    avatar.innerHTML = '<i class="fa-solid fa-robot text-xs"></i>';
                    
                    const contentWrapper = document.createElement("div");
                    contentWrapper.className = "flex-1 bg-white rounded-lg p-4 shadow-sm border text-gray-800 prose prose-indigo max-w-none relative";
                    contentWrapper.innerHTML = marked.parse(msg.content);
                    
                    // Render citations if available
                    if (msg.citations && msg.citations !== "null" && msg.citations !== "[]") {
                        try {
                            const citations = JSON.parse(msg.citations);
                            if(citations && citations.length > 0) {
                                const citationsDiv = document.createElement("div");
                                citationsDiv.className = "mt-4 pt-3 border-t border-gray-100 text-xs text-gray-500";
                                citationsDiv.innerHTML = "<strong>Citations:</strong><ul class='list-disc pl-4 mt-1'></ul>";
                                const ul = citationsDiv.querySelector("ul");
                                
                                citations.forEach((c, index) => {
                                    const li = document.createElement("li");
                                    li.innerHTML = `<span class="cursor-pointer hover:text-indigo-600" title="${c.ContentSnippet}">[${index + 1}] ${c.FileName} (Page ${c.Page})</span>`;
                                    ul.appendChild(li);
                                });
                                contentWrapper.appendChild(citationsDiv);
                            }
                        } catch(e) {}
                    }
                    
                    msgWrapper.appendChild(avatar);
                    msgWrapper.appendChild(contentWrapper);
                }
                
                chatMessages.appendChild(msgWrapper);
            });
            
            chatMessages.scrollTop = chatMessages.scrollHeight;
        });

        connection.on("ReceiveToken", (token, isEnd) => {
            const chatMessages = document.getElementById("chatMessages");
            
            if (isReceivingStream == false && isEnd == false && token === "") {
                removeThinkingIndicator();
                // Start of a new message stream
                isReceivingStream = true;
                currentAssistantMarkdown = "";
                
                if (!currentAssistantMessageDiv) {
                    // Fallback in case bubble wasn't created
                    const msgWrapper = document.createElement("div");
                    msgWrapper.className = "flex items-start gap-4";
                    const avatar = document.createElement("div");
                    avatar.className = "w-8 h-8 rounded bg-indigo-600 flex items-center justify-center text-white flex-shrink-0 mt-1 shadow-sm";
                    avatar.innerHTML = '<i class="fa-solid fa-robot text-xs"></i>';
                    const contentWrapper = document.createElement("div");
                    contentWrapper.className = "flex-1 bg-white rounded-lg p-4 shadow-sm border text-gray-800 prose prose-indigo max-w-none relative";
                    msgWrapper.appendChild(avatar);
                    msgWrapper.appendChild(contentWrapper);
                    chatMessages.appendChild(msgWrapper);
                    currentAssistantMessageDiv = contentWrapper;
                }
                
                // Show blinking cursor
                currentAssistantMessageDiv.innerHTML = '<span class="text-indigo-500 animate-pulse font-bold text-lg">▍</span>';
                chatMessages.scrollTop = chatMessages.scrollHeight;
            } else if (isReceivingStream && isEnd == false) {
                // Append token
                currentAssistantMarkdown += token;
                
                // Update HTML using marked and append blinking cursor
                currentAssistantMessageDiv.innerHTML = marked.parse(currentAssistantMarkdown) + '<span class="text-indigo-500 animate-pulse font-bold text-lg inline-block ml-1">▍</span>';
                chatMessages.scrollTop = chatMessages.scrollHeight;
            } else if (isEnd) {
                // End of stream, token contains citations JSON
                isReceivingStream = false;
                
                // Render final markdown without blinking cursor
                if (currentAssistantMessageDiv) {
                    currentAssistantMessageDiv.innerHTML = marked.parse(currentAssistantMarkdown);
                }
                
                if(token && token !== "null" && token !== "[]") {
                    try {
                        const citations = JSON.parse(token);
                        if(citations && citations.length > 0) {
                            const citationsDiv = document.createElement("div");
                            citationsDiv.className = "mt-4 pt-3 border-t border-gray-100 text-xs text-gray-500";
                            citationsDiv.innerHTML = "<strong>Citations:</strong><ul class='list-disc pl-4 mt-1'></ul>";
                            const ul = citationsDiv.querySelector("ul");
                            
                            citations.forEach((c, index) => {
                                const li = document.createElement("li");
                                li.innerHTML = `<span class="cursor-pointer hover:text-indigo-600" title="${c.ContentSnippet}">[${index + 1}] ${c.FileName} (Page ${c.Page})</span>`;
                                ul.appendChild(li);
                            });
                            currentAssistantMessageDiv.appendChild(citationsDiv);
                        }
                    } catch (e) { console.error("Could not parse citations", e); }
                }
                chatMessages.scrollTop = chatMessages.scrollHeight;
            }
        });

        connection.on("ReceiveError", (errorMsg) => {
            removeThinkingIndicator();
            isReceivingStream = false;
            const chatMessages = document.getElementById("chatMessages");
            
            if (currentAssistantMessageDiv) {
                currentAssistantMessageDiv.innerHTML = `<div class="text-red-500 font-medium"><i class="fa-solid fa-circle-exclamation mr-1"></i> ${errorMsg}</div>`;
            } else {
                const errDiv = document.createElement("div");
                errDiv.className = "flex justify-center my-4";
                errDiv.innerHTML = `<div class="bg-red-100 text-red-800 text-xs px-3 py-1 rounded-full">${errorMsg}</div>`;
                chatMessages.appendChild(errDiv);
            }
            chatMessages.scrollTop = chatMessages.scrollHeight;
        });

        document.getElementById("chatForm").addEventListener("submit", async (e) => {
            e.preventDefault();
            if (!currentSubjectId) return;
            
            const messageInput = document.getElementById("messageInput");
            const message = messageInput.value.trim();
            if (!message) return;
            
            messageInput.value = "";
            
            // Add user message to UI
            const chatMessages = document.getElementById("chatMessages");
            const msgWrapper = document.createElement("div");
            msgWrapper.className = "flex flex-row-reverse items-start gap-4";
            
            const avatar = document.createElement("div");
            avatar.className = "w-8 h-8 rounded bg-gray-200 flex items-center justify-center text-gray-600 flex-shrink-0 mt-1";
            avatar.innerHTML = '<i class="fa-solid fa-user text-xs"></i>';
            
            const contentWrapper = document.createElement("div");
            contentWrapper.className = "bg-indigo-600 text-white rounded-lg py-2 px-4 shadow max-w-[80%]";
            contentWrapper.innerText = message;
            
            msgWrapper.appendChild(avatar);
            msgWrapper.appendChild(contentWrapper);
            chatMessages.appendChild(msgWrapper);
            chatMessages.scrollTop = chatMessages.scrollHeight;
            
            // Send to Hub
            try {
                showThinkingIndicator();
                await connection.send("SendMessage", currentSessionId, currentSubjectId, message);
            } catch (err) {
                console.error(err);
                removeThinkingIndicator();
                if (currentAssistantMessageDiv) {
                    currentAssistantMessageDiv.innerHTML = `<div class="text-red-500 font-medium"><i class="fa-solid fa-circle-exclamation mr-1"></i> Có lỗi xảy ra khi gửi tin nhắn.</div>`;
                }
            }
        });

        // Handle Enter to submit, Shift+Enter for new line
        document.getElementById("messageInput").addEventListener("keydown", function(e) {
            if (e.key === "Enter" && !e.shiftKey) {
                e.preventDefault();
                document.getElementById("chatForm").dispatchEvent(new Event("submit"));
            }
        });
    </script>
}
