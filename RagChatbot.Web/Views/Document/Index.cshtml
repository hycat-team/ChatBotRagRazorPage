@model IEnumerable<RagChatbot.Web.Models.Entities.Document>

@{
    ViewData["Title"] = "Manage Documents";
    var subjects = ViewBag.Subjects as IEnumerable<RagChatbot.Web.Models.Entities.Subject>;
}

<div class="flex-1 overflow-y-auto w-full scrollbar-thin">
    <div class="max-w-7xl mx-auto p-6 space-y-6">
        <div class="flex justify-between items-center">
            <h1 class="text-3xl font-bold text-gray-900">Document Management</h1>
        </div>

        @if (TempData["Error"] != null)
        {
            <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative">
                @TempData["Error"]
            </div>
        }

        @if (TempData["Success"] != null)
        {
            <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded relative">
                @TempData["Success"]
            </div>
        }

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <!-- Add Subject -->
            <div class="bg-white p-6 rounded-lg shadow-sm border">
                <h2 class="text-xl font-semibold mb-4">Add Subject</h2>
                <form asp-action="CreateSubject" method="post" class="space-y-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700">Code</label>
                        <input type="text" name="code" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-primary focus:ring focus:ring-primary focus:ring-opacity-50 p-2 border" required />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700">Name</label>
                        <input type="text" name="name" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-primary focus:ring focus:ring-primary focus:ring-opacity-50 p-2 border" required />
                    </div>
                    <button type="submit" class="bg-primary text-white px-4 py-2 rounded shadow hover:bg-indigo-700">Create Subject</button>
                </form>
            </div>

            <!-- Upload Document -->
            <div class="bg-white p-6 rounded-lg shadow-sm border">
                <h2 class="text-xl font-semibold mb-4">Upload Document</h2>
                <form asp-action="Upload" method="post" enctype="multipart/form-data" class="space-y-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700">Subject</label>
                        <select name="subjectId" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-primary focus:ring focus:ring-primary focus:ring-opacity-50 p-2 border" required>
                            <option value="" disabled selected>-- Select a Subject --</option>
                            @if (subjects != null)
                            {
                                foreach (var s in subjects)
                                {
                                    <option value="@s.Id">@s.Code - @s.Name</option>
                                }
                            }
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700">File (PDF, DOCX)</label>
                        <input type="file" name="file" accept=".pdf,.docx" class="mt-1 block w-full text-sm text-gray-500
                          file:mr-4 file:py-2 file:px-4
                          file:rounded-full file:border-0
                          file:text-sm file:font-semibold
                          file:bg-indigo-50 file:text-indigo-700
                          hover:file:bg-indigo-100" required />
                    </div>
                    <button type="submit" class="bg-primary text-white px-4 py-2 rounded shadow hover:bg-indigo-700">Upload</button>
                </form>
            </div>
        </div>

        <!-- Document List -->
        <div class="bg-white rounded-lg shadow-sm border overflow-hidden">
            <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider bg-gray-50">File Name</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider bg-gray-50">Subject</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider bg-gray-50">Status</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider bg-gray-50">Date</th>
                    </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-200">
                    @foreach (var doc in Model)
                    {
                        <tr>
                            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">@doc.FileName</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">@doc.Subject?.Code</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                                @if (doc.Status == "Indexed")
                                {
                                    @if (doc.DocumentChunks.Count == 0)
                                    {
                                        <div class="inline-flex flex-col">
                                            <span class="px-2 py-0.5 inline-flex text-xs leading-5 font-semibold rounded-full bg-yellow-100 text-yellow-800">
                                                Indexed
                                            </span>
                                            <span class="text-[10px] text-amber-600 mt-1 font-medium max-w-[200px] whitespace-normal" title="No text characters could be extracted from this PDF. This happens when the PDF is scanned or exported from Canva with 'Flatten PDF' checked. Please re-export it with text enabled.">
                                                ⚠️ No text extracted (Scanned/Flattened PDF)
                                            </span>
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 text-green-800">@doc.Status (@doc.DocumentChunks.Count chunks)</span>
                                    }
                                }
                                else if (doc.Status == "Processing")
                                {
                                    <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-blue-100 text-blue-800">@doc.Status</span>
                                }
                                else if (doc.Status == "Failed")
                                {
                                    <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-red-100 text-red-800">@doc.Status</span>
                                }
                                else
                                {
                                    <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-yellow-100 text-yellow-800">@doc.Status</span>
                                }
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">@doc.UploadedAt.ToLocalTime().ToString("g")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    /* Sleek premium scrollbar */
    .scrollbar-thin::-webkit-scrollbar {
        width: 6px;
        height: 6px;
    }
    .scrollbar-thin::-webkit-scrollbar-track {
        background: #f8fafc;
        border-radius: 4px;
    }
    .scrollbar-thin::-webkit-scrollbar-thumb {
        background: #cbd5e1;
        border-radius: 4px;
    }
    .scrollbar-thin::-webkit-scrollbar-thumb:hover {
        background: #94a3b8;
    }
</style>
