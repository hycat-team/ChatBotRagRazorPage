@page
@model RagChatbot.PresentationRazorPage.Pages.Admin.SubjectsModel
@{
    ViewData["Title"] = "Quản lý Môn học";
    var departments = ViewBag.Departments as IEnumerable<RagChatbot.DataAccess.EntityModels.Department>;
}

<div class="max-w-6xl mx-auto p-4 sm:p-6 lg:p-8 transition-colors duration-200">
    @if (TempData["Error"] != null)
    {
        <div class="mb-4 p-4 text-sm text-red-700 bg-red-100 rounded-xl dark:bg-red-200 dark:text-red-800 animate-pulse">
            <i class="fa-solid fa-circle-exclamation mr-2"></i> @TempData["Error"]
        </div>
    }
    @if (TempData["Success"] != null)
    {
        <div class="mb-4 p-4 text-sm text-emerald-700 bg-emerald-100 rounded-xl dark:bg-emerald-200 dark:text-emerald-800">
            <i class="fa-solid fa-circle-check mr-2"></i> @TempData["Success"]
        </div>
    }
    <div class="flex items-center justify-between mb-8">
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white flex items-center gap-3">
            <span class="w-10 h-10 rounded-xl bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 flex items-center justify-center">
                <i class="fa-solid fa-book"></i>
            </span>
            Quản lý Môn học
        </h1>
        
        <a asp-page="/Admin/Index" class="px-4 py-2 bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 rounded-lg text-sm font-semibold hover:bg-slate-200 dark:hover:bg-slate-700 transition">
            <i class="fa-solid fa-arrow-left mr-2"></i>Quay lại QL Tài khoản
        </a>
    </div>

    

    

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        
        <!-- Form Tạo Môn học -->
        <div class="lg:col-span-1">
            <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-2xl p-6 shadow-sm sticky top-20">
                <h2 class="text-base font-bold text-gray-900 dark:text-white mb-5 flex items-center gap-2">
                    <i class="fa-solid fa-plus text-emerald-500 dark:text-emerald-400"></i>
                    Tạo Môn học mới
                </h2>
                
                <!-- Tabs -->
                <div class="flex gap-2 mb-6 p-1 bg-slate-100 dark:bg-slate-800/50 rounded-xl">
                    <button type="button" onclick="switchSubjectTab('manual')" id="tabSubManual" class="flex-1 py-2 px-3 text-sm font-semibold rounded-lg bg-white dark:bg-slate-700 shadow-sm text-gray-900 dark:text-white transition-all">Tạo thủ công</button>
                    <button type="button" onclick="switchSubjectTab('bulk')" id="tabSubBulk" class="flex-1 py-2 px-3 text-sm font-semibold rounded-lg text-slate-500 hover:text-slate-700 dark:text-slate-400 dark:hover:text-slate-200 transition-all">Import File</button>
                </div>
                
                <form asp-page="/Admin/Subjects" asp-page-handler="CreateSubject" method="post" id="formSubManual" class="space-y-4">
                    <div>
                        <label class="block text-xs font-semibold text-slate-500 dark:text-slate-400 mb-1.5 uppercase tracking-wider">Mã môn</label>
                        <input type="text" name="code" required placeholder="VD: TRIET01"
                                class="w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-2.5 text-sm text-gray-900 dark:text-white placeholder-slate-400 focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/20 outline-none transition-all" />
                    </div>
                    
                    <div>
                        <label class="block text-xs font-semibold text-slate-500 dark:text-slate-400 mb-1.5 uppercase tracking-wider">Tên môn học</label>
                        <input type="text" name="name" required placeholder="VD: Triết học Mác – Lê Nin"
                                class="w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-2.5 text-sm text-gray-900 dark:text-white placeholder-slate-400 focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/20 outline-none transition-all" />
                    </div>

                    <div>
                        <label class="block text-xs font-semibold text-slate-500 dark:text-slate-400 mb-1.5 uppercase tracking-wider">Bộ môn</label>
                        <select name="departmentId" required
                                class="w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-2.5 text-sm text-gray-900 dark:text-white outline-none focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/20 transition-all">
                            <option value="">-- Chọn bộ môn --</option>
                            @if (departments != null)
                            {
                                foreach (var dept in departments)
                                {
                                    <option value="@dept.Id">@dept.Name</option>
                                }
                            }
                        </select>
                    </div>
                    
                    <button type="submit"
                        class="w-full mt-2 bg-emerald-600 hover:bg-emerald-700 text-white text-sm font-semibold py-3 px-4 rounded-xl shadow-sm shadow-emerald-500/30 transition-all flex items-center justify-center gap-2">
                        <span>Tạo môn học</span>
                        <i class="fa-solid fa-plus text-xs"></i>
                    </button>
                </form>
                
                <form asp-page="/Admin/Subjects" asp-page-handler="CreateSubjectsBulk" method="post" enctype="multipart/form-data" id="formSubBulk" class="space-y-4 hidden">
                    <div>
                        <label class="block text-xs font-semibold text-slate-500 dark:text-slate-400 mb-1.5 uppercase tracking-wider">Bộ môn</label>
                        <select name="departmentId" required
                                class="w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-2.5 text-sm text-gray-900 dark:text-white outline-none focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/20 transition-all">
                            <option value="">-- Chọn bộ môn --</option>
                            @if (departments != null)
                            {
                                foreach (var dept in departments)
                                {
                                    <option value="@dept.Id">@dept.Name</option>
                                }
                            }
                        </select>
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-slate-500 dark:text-slate-400 mb-1.5 uppercase tracking-wider">
                            File .TXT / .CSV
                        </label>
                        <p class="text-[10px] text-slate-400 mb-2">Định dạng mỗi dòng: <code class="bg-slate-100 dark:bg-slate-800 px-1 rounded">CODE, Tên môn học</code></p>
                        <input type="file" name="file" accept=".txt,.csv" required
                               class="w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-2.5 text-sm text-gray-900 dark:text-white placeholder-slate-400 focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/20 outline-none transition-all" />
                    </div>
                    
                    <button type="submit"
                        class="w-full mt-2 bg-emerald-600 hover:bg-emerald-700 text-white text-sm font-semibold py-3 px-4 rounded-xl shadow-sm shadow-emerald-500/30 transition-all flex items-center justify-center gap-2">
                        <span>Import File</span>
                        <i class="fa-solid fa-file-import text-xs"></i>
                    </button>
                </form>
            </div>
        </div>

        <!-- Danh sách Môn học -->
        <div class="lg:col-span-2">
            <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-2xl shadow-sm overflow-hidden">
                <div class="px-6 py-5 border-b border-slate-100 dark:border-slate-800/60 bg-slate-50/50 dark:bg-slate-900/50 flex items-center justify-between">
                    <h3 class="text-base font-bold text-gray-900 dark:text-white flex items-center gap-2">
                        <i class="fa-solid fa-layer-group text-emerald-500 dark:text-emerald-400"></i>
                        Danh sách Môn học
                    </h3>
                    <span class="bg-emerald-100 dark:bg-emerald-500/20 text-emerald-700 dark:text-emerald-400 text-xs font-bold px-2.5 py-1 rounded-full">
                        @Model.SubjectsList.Count() môn học
                    </span>
                </div>
                
                <div class="overflow-x-auto">
                    <table class="w-full text-left text-sm text-slate-600 dark:text-slate-300">
                        <thead class="bg-slate-50 dark:bg-slate-950/50 text-xs uppercase font-semibold text-slate-500 dark:text-slate-400 border-b border-slate-200 dark:border-slate-800">
                            <tr>
                                <th scope="col" class="px-6 py-4">Mã Môn</th>
                                <th scope="col" class="px-6 py-4">Tên Môn học</th>
                                <th scope="col" class="px-6 py-4">Bộ môn</th>
                                <th scope="col" class="px-6 py-4">Trạng thái</th>
                                <th scope="col" class="px-6 py-4">Người quản lý</th>
                                @* <th scope="col" class="px-6 py-4">Thao tác</th> *@
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-100 dark:divide-slate-800/60">
                            @if (!Model.SubjectsList.Any())
                            {
                                <tr>
                                    <td colspan="6" class="px-6 py-12 text-center text-slate-500">Chưa có môn học nào.</td>
                                </tr>
                            }
                            else
                            {
                                foreach (var subject in Model.SubjectsList)
                                {
                                    <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/30 transition-colors group">
                                        <td class="px-6 py-4 font-mono text-xs font-bold text-slate-500 dark:text-slate-400">@subject.Code</td>
                                        <td class="px-6 py-4 font-bold text-gray-900 dark:text-slate-100">@subject.Name</td>
                                        <td class="px-6 py-4">
                                            @if (subject.Department != null)
                                            {
                                                <span class="px-2 py-1 bg-blue-50 dark:bg-blue-500/10 text-blue-600 dark:text-blue-400 rounded text-xs font-medium border border-blue-100 dark:border-blue-500/20">
                                                    @subject.Department.Name
                                                </span>
                                            }
                                        </td>
                                        <td class="px-6 py-4 text-xs">
                                            @if (subject.IsActive)
                                            {
                                                <span class="px-2 py-1 bg-emerald-50 dark:bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 rounded text-xs font-medium border border-emerald-100 dark:border-emerald-500/20">
                                                    Active
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="px-2 py-1 bg-slate-100 dark:bg-slate-800 text-slate-500 dark:text-slate-400 rounded text-xs font-medium border border-slate-200 dark:border-slate-700">
                                                    Inactive
                                                </span>
                                            }
                                        </td>
                                        <td class="px-6 py-4">
                                            @{
                                                var manager = subject.Department?.Users?.FirstOrDefault(u => u.Role == "HeadOfDepartment");
                                            }
                                            @if (manager != null)
                                            {
                                                <span class="text-sm font-medium text-gray-900 dark:text-white">@manager.LastName @manager.FirstName</span>
                                            }
                                            else
                                            {
                                                <span class="text-xs text-gray-500 italic">Trống</span>
                                            }
                                        </td>
                                        <td class="px-6 py-4">
                                            <form asp-page-handler="ToggleActive" method="post" class="inline" onsubmit="event.preventDefault(); toggleActiveAjax(this);">
                                                <input type="hidden" name="id" value="@subject.Id" />
                                                @* <button type="submit" 
                                                        class="relative inline-flex items-center h-5 w-9 rounded-full transition-colors focus:outline-none @(subject.IsActive ? "bg-emerald-500" : "bg-slate-300 dark:bg-slate-600")"
                                                        title="@(subject.IsActive ? "Vô hiệu hóa" : "Kích hoạt")">
                                                    <span class="inline-block w-4 h-4 transform rounded-full bg-white transition-transform" style="@(subject.IsActive ? "transform: translateX(18px);" : "transform: translateX(2px);")"></span>
                                                </button> *@
                                            </form>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>

            </div>
        </div>
    </div>
</div>

<script>
    function confirmDeleteSubject(id, name) {
        if (confirm(`Bạn có chắc chắn muốn xóa môn học "${name}" không?`)) {
            const form = document.createElement('form');
            form.method = 'post';
            form.action = `/Admin/DeleteSubject/${id}`;
            document.body.appendChild(form);
            form.submit();
        }
    }

    function switchSubjectTab(tab) {
        const manualTab = document.getElementById('tabSubManual');
        const bulkTab = document.getElementById('tabSubBulk');
        const manualForm = document.getElementById('formSubManual');
        const bulkForm = document.getElementById('formSubBulk');

        const activeClasses = ['bg-white', 'dark:bg-slate-700', 'shadow-sm', 'text-gray-900', 'dark:text-white'];
        const inactiveClasses = ['text-slate-500', 'hover:text-slate-700', 'dark:text-slate-400', 'dark:hover:text-slate-200'];

        if (tab === 'manual') {
            manualForm.classList.remove('hidden');
            bulkForm.classList.add('hidden');
            
            manualTab.classList.add(...activeClasses);
            manualTab.classList.remove(...inactiveClasses);
            
            bulkTab.classList.remove(...activeClasses);
            bulkTab.classList.add(...inactiveClasses);
        } else {
            manualForm.classList.add('hidden');
            bulkForm.classList.remove('hidden');
            
            bulkTab.classList.add(...activeClasses);
            bulkTab.classList.remove(...inactiveClasses);
            
            manualTab.classList.remove(...activeClasses);
            manualTab.classList.add(...inactiveClasses);
        }
    }

        async function toggleActiveAjax(form) {
        try {
            const formData = new FormData(form);
            const res = await fetch('?handler=ToggleActive', {
                method: 'POST',
                body: formData
            });

            if (res.ok) {
                // Nếu thành công thì mới reload để cập nhật giao diện hiển thị giao diện mới
                window.location.reload();
            } else {
                // Nếu rơi vào các khối BadRequest phía trên, res.text() sẽ lấy ra câu báo lỗi cụ thể
                const errorMessage = await res.text();
                alert("Thông báo từ hệ thống: " + errorMessage);
            }
        } catch (error) {
            console.error("Lỗi kết nối:", error);
            alert("Đã xảy ra lỗi kết nối đến server.");
        }
    }
</script>

<style>
    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(-10px); }
        to { opacity: 1; transform: translateY(0); }
    }
    
    .custom-scrollbar::-webkit-scrollbar {
        width: 6px;
    }
    .custom-scrollbar::-webkit-scrollbar-track {
        background: transparent;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb {
        background-color: #cbd5e1;
        border-radius: 20px;
    }
    .dark .custom-scrollbar::-webkit-scrollbar-thumb {
        background-color: #334155;
    }
</style>
