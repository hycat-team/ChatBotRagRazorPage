@model RagChatbot.Presentation.ViewModels.RegisterViewModel
@{
    Layout = null; // No header/footer for the register page
    ViewData["Title"] = "Đăng ký tài khoản";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – RAG Chatbot</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        // Prevent FOUC
        if (localStorage.theme === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.add('dark');
        } else {
            document.documentElement.classList.remove('dark');
        }
        tailwind.config = {
            darkMode: 'class',
            theme: { extend: {} }
        }
    </script>
    <style>
        body { font-family: 'Inter', sans-serif; }
        
        /* Stunning Light background */
        body {
            background-color: #f8fafc; /* slate-50 */
            background-image: 
                radial-gradient(at 0% 0%, hsla(152,81%,89%,1) 0px, transparent 50%),
                radial-gradient(at 100% 100%, hsla(160,84%,88%,1) 0px, transparent 50%);
            transition: background-color 0.3s ease;
        }
        
        .dark body {
            background-color: #000000; /* pure black */
            background-image: 
                radial-gradient(at 0% 0%, hsla(152,81%,10%,1) 0px, transparent 50%),
                radial-gradient(at 100% 100%, hsla(160,84%,5%,1) 0px, transparent 50%);
        }
        
        /* Premium Card */
        .glass-card {
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid rgba(255, 255, 255, 1);
            box-shadow: 0 10px 40px -10px rgba(4, 120, 87, 0.15);
        }
        .dark .glass-card {
            background: rgba(9, 9, 11, 0.85); /* zinc-950/85 */
            border: 1px solid rgba(6, 78, 59, 0.5); /* emerald-900/50 */
            box-shadow: 0 10px 40px -10px rgba(0, 0, 0, 0.5);
        }

        .input-light {
            background: #ffffff;
            border: 1px solid #d1d5db;
            color: #1f2937;
            transition: all 0.3s ease;
        }
        .dark .input-light {
            background: rgba(0, 0, 0, 0.6);
            border: 1px solid rgba(6, 78, 59, 1);
            color: #f8fafc;
        }

        .input-light:focus {
            background: #ffffff;
            border-color: #10b981; /* Emerald 500 */
            outline: none;
            box-shadow: 0 0 0 4px rgba(16, 185, 129, 0.15);
        }
        .dark .input-light:focus {
            background: rgba(2, 44, 34, 0.9);
            border-color: #34d399; /* emerald-400 */
            box-shadow: 0 0 0 4px rgba(52, 211, 153, 0.15);
        }

        /* Input auto-fill override */
        input:-webkit-autofill,
        input:-webkit-autofill:hover, 
        input:-webkit-autofill:focus, 
        input:-webkit-autofill:active{
            -webkit-box-shadow: 0 0 0 30px #ffffff inset !important;
            -webkit-text-fill-color: #1f2937 !important;
            transition: background-color 5000s ease-in-out 0s;
        }
    </style>
</head>
<body class="min-h-screen flex items-center justify-center relative overflow-hidden">
    
    <!-- Register Container -->
    <div class="w-full max-w-md px-6 relative z-10 my-8">
        <div class="glass-card rounded-3xl p-10 transform transition-all hover:scale-[1.01] duration-300">
            <!-- Logo & Title -->
            <div class="text-center mb-6">
                <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-gradient-to-br from-emerald-500 to-green-600 shadow-lg shadow-emerald-500/30 mb-4">
                    <i class="fa-solid fa-user-plus text-3xl text-white"></i>
                </div>
                <h2 class="text-3xl font-bold text-gray-800 dark:text-emerald-50 mb-2">Đăng Ký</h2>
                <p class="text-emerald-600 dark:text-emerald-400 text-sm font-medium">Tạo tài khoản RAG Chatbot</p>
            </div>
 
            <!-- Error Alert -->
            @if (ViewBag.Error != null)
            {
                <div class="bg-red-50 dark:bg-red-900/30 border border-red-200 dark:border-red-800/50 text-red-600 dark:text-red-400 px-4 py-3 rounded-xl mb-6 flex items-center gap-3">
                    <i class="fa-solid fa-circle-exclamation"></i>
                    <span class="text-sm font-medium">@ViewBag.Error</span>
                </div>
            }

            <!-- Form -->
            <form asp-action="Register" method="post" class="space-y-4">
                
                <div>
                    <label class="block text-sm font-semibold text-gray-700 dark:text-emerald-200 mb-1.5 ml-1">Tên đăng nhập</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none text-emerald-500 dark:text-emerald-400">
                            <i class="fa-solid fa-user"></i>
                        </div>
                        <input asp-for="Username" class="input-light w-full rounded-xl py-3 pl-11 pr-4 placeholder-gray-400 dark:placeholder-emerald-600/70" placeholder="Chữ cái, số và dấu gạch dưới..." required />
                    </div>
                    <span asp-validation-for="Username" class="text-red-500 text-xs mt-1 block font-medium"></span>
                </div>
                
                <div>
                    <label class="block text-sm font-semibold text-gray-700 dark:text-emerald-200 mb-1.5 ml-1">Mật khẩu</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none text-emerald-500 dark:text-emerald-400">
                            <i class="fa-solid fa-lock"></i>
                        </div>
                        <input asp-for="Password" class="input-light w-full rounded-xl py-3 pl-11 pr-4 placeholder-gray-400 dark:placeholder-emerald-600/70" placeholder="Tối thiểu 6 ký tự..." required type="password" />
                    </div>
                    <span asp-validation-for="Password" class="text-red-500 text-xs mt-1 block font-medium"></span>
                </div>

                <div>
                    <label class="block text-sm font-semibold text-gray-700 dark:text-emerald-200 mb-1.5 ml-1">Xác nhận mật khẩu</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none text-emerald-500 dark:text-emerald-400">
                            <i class="fa-solid fa-check-double"></i>
                        </div>
                        <input asp-for="ConfirmPassword" class="input-light w-full rounded-xl py-3 pl-11 pr-4 placeholder-gray-400 dark:placeholder-emerald-600/70" placeholder="Nhập lại mật khẩu..." required type="password" />
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="text-red-500 text-xs mt-1 block font-medium"></span>
                </div>
                
                <div class="pt-4">
                    <button type="submit" class="w-full bg-gradient-to-r from-emerald-500 to-green-600 hover:from-emerald-600 hover:to-green-700 text-white font-semibold py-3.5 px-4 rounded-xl shadow-lg shadow-emerald-500/30 transition-all duration-300 transform hover:-translate-y-0.5 active:translate-y-0">
                        Đăng ký tài khoản <i class="fa-solid fa-user-plus ml-2 text-sm"></i>
                    </button>
                </div>

                <div class="text-center mt-6 text-sm text-gray-600 dark:text-emerald-400 font-medium">
                    Đã có tài khoản? <a href="/Auth/Login" class="text-emerald-500 hover:underline font-semibold">Đăng nhập ngay</a>
                </div>
            </form>
        </div>
        
        <p class="text-center text-gray-500 dark:text-emerald-400/50 text-sm mt-8">
            &copy; @DateTime.Now.Year RAG Chatbot. Mọi quyền được bảo lưu.
        </p>
    </div>

</body>
</html>
