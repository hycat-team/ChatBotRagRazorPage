@model IEnumerable<RagChatbot.DataAccess.EntityModels.AppUser>
@{
    ViewData["Title"] = "Quản lý Người dùng";
}

<div class="h-full w-full overflow-y-auto custom-scrollbar">
    <div class="max-w-6xl mx-auto p-4 sm:p-6 lg:p-8 transition-colors duration-200">
    <div class="flex items-center justify-between mb-8">
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white flex items-center gap-3">
            <span class="w-10 h-10 rounded-xl bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 flex items-center justify-center">
                <i class="fa-solid fa-users-gear"></i>
            </span>
            Quản lý Người dùng
        </h1>
        
        <div class="flex items-center gap-3">
            <a asp-controller="Admin" asp-action="HeadOfDepartments" class="px-4 py-2 bg-orange-100 dark:bg-orange-500/20 text-orange-700 dark:text-orange-400 rounded-lg text-sm font-semibold hover:bg-orange-200 dark:hover:bg-orange-500/30 transition">
                <i class="fa-solid fa-user-tie mr-2"></i>Quản lý HOD
            </a>
            <a asp-controller="Admin" asp-action="Departments" class="px-4 py-2 bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 rounded-lg text-sm font-semibold hover:bg-slate-200 dark:hover:bg-slate-700 transition">
                <i class="fa-solid fa-building mr-2"></i>Quản lý Bộ môn
            </a>
        </div>
    </div>

    <!-- Alert Messages -->
    @if (TempData["Success"] != null)
    {
        <div class="mb-6 rounded-xl bg-emerald-50 dark:bg-emerald-500/10 p-4 border border-emerald-200 dark:border-emerald-500/20 flex items-start gap-3 shadow-sm animate-[fadeIn_0.3s_ease-out]">
            <i class="fa-solid fa-circle-check text-emerald-500 mt-0.5"></i>
            <div class="text-sm font-medium text-emerald-800 dark:text-emerald-300">
                @TempData["Success"]
            </div>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="mb-6 rounded-xl bg-red-50 dark:bg-red-500/10 p-4 border border-red-200 dark:border-red-500/20 flex items-start gap-3 shadow-sm animate-[fadeIn_0.3s_ease-out]">
            <i class="fa-solid fa-circle-exclamation text-red-500 mt-0.5"></i>
            <div class="text-sm font-medium text-red-800 dark:text-red-300">
                @TempData["Error"]
            </div>
        </div>
    }

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        
        <!-- Form Tạo Người dùng -->
        <div class="lg:col-span-1">
            <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-2xl p-6 shadow-sm sticky top-6">
                <h2 class="text-base font-bold text-gray-900 dark:text-white mb-5 flex items-center gap-2">
                    <i class="fa-solid fa-user-plus text-emerald-500 dark:text-emerald-400"></i>
                    Tạo tài khoản mới
                </h2>
                
                <form asp-controller="Admin" asp-action="CreateUsers" method="post" enctype="multipart/form-data" class="space-y-4">
                    <div>
                        <label class="block text-xs font-semibold text-slate-500 dark:text-slate-400 mb-1.5 uppercase tracking-wider">Phân quyền</label>
                        <select name="role" id="roleSelect" class="w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-2.5 text-sm text-gray-900 dark:text-white outline-none focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/20 transition-all" onchange="toggleDepartment()">
                            <option value="Student">Học sinh (Student)</option>
                            <option value="Lecturer">Giảng viên (Lecturer)</option>
                        </select>
                    </div>

                    <div id="deptWrapper" style="display: none;">
                        <label class="block text-xs font-semibold text-slate-500 dark:text-slate-400 mb-1.5 uppercase tracking-wider">Chọn Bộ môn</label>
                        <select name="departmentId" class="w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-2.5 text-sm text-gray-900 dark:text-white outline-none focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/20 transition-all">
                            <option value="">-- Vui lòng chọn --</option>
                            @if(ViewBag.Departments != null)
                            {
                                foreach(var dept in ViewBag.Departments)
                                {
                                    <option value="@dept.Id">@dept.Name</option>
                                }
                            }
                        </select>
                    </div>
                    
                    <div>
                        <label class="block text-xs font-semibold text-slate-500 dark:text-slate-400 mb-1.5 uppercase tracking-wider">
                            Import File Tạo Tài Khoản (.csv, .txt)
                        </label>
                        <p class="text-[10px] text-slate-400 mb-2">Mỗi dòng 1 người. Định dạng: <code class="bg-slate-100 dark:bg-slate-800 px-1 rounded">Email, Họ, Tên</code><br>Mật khẩu mặc định: <b>123456</b></p>
                        <input type="file" name="file" accept=".csv,.txt" required
                               class="w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-2.5 text-sm text-gray-900 dark:text-white placeholder-slate-400 focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/20 outline-none transition-all" />
                    </div>
                    
                    <div class="flex gap-2 mt-2">
                        <button type="submit"
                            class="flex-1 bg-emerald-600 hover:bg-emerald-700 text-white text-sm font-semibold py-3 px-2 rounded-xl shadow-sm shadow-emerald-500/30 transition-all flex items-center justify-center gap-1">
                            <span>Import CSV</span>
                        </button>
                        <button type="button" onclick="openSingleUserModal()"
                            class="flex-1 bg-slate-100 hover:bg-slate-200 dark:bg-slate-800 dark:hover:bg-slate-700 text-slate-700 dark:text-slate-300 text-sm font-semibold py-3 px-2 rounded-xl transition-all flex items-center justify-center gap-1 border border-slate-200 dark:border-slate-700">
                            <span>Tạo 1 TK</span>
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <!-- Danh sách Người dùng -->
        <div class="lg:col-span-2 space-y-6">
            
            <!-- Form Tìm kiếm -->
            <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-2xl p-4 shadow-sm">
                <form asp-controller="Admin" asp-action="Index" method="get" class="flex gap-2">
                    <div class="relative flex-1">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <i class="fa-solid fa-magnifying-glass text-slate-400"></i>
                        </div>
                        <input type="text" name="searchEmail" value="@ViewContext.HttpContext.Request.Query["searchEmail"]" class="w-full pl-10 pr-4 py-2.5 bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-700 rounded-xl text-sm focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/20 outline-none transition-all dark:text-white" placeholder="Tìm kiếm theo Email..." />
                    </div>
                    <button type="submit" class="bg-slate-800 hover:bg-slate-900 dark:bg-slate-700 dark:hover:bg-slate-600 text-white text-sm font-semibold py-2.5 px-6 rounded-xl transition-all">
                        Tìm kiếm
                    </button>
                    @if(!string.IsNullOrEmpty(ViewContext.HttpContext.Request.Query["searchEmail"]))
                    {
                        <a asp-controller="Admin" asp-action="Index" class="bg-rose-100 text-rose-600 hover:bg-rose-200 dark:bg-rose-500/20 dark:text-rose-400 dark:hover:bg-rose-500/30 text-sm font-semibold py-2.5 px-4 rounded-xl transition-all flex items-center">
                            <i class="fa-solid fa-xmark"></i>
                        </a>
                    }
                </form>
            </div>
            
            @{
                var sections = new[] {
                    new { Title = "Học sinh", Role = "Student", Icon = "fa-user-graduate", Data = Model.Where(u => u.Role == "Student") },
                    new { Title = "Giảng viên", Role = "Lecturer", Icon = "fa-chalkboard-user", Data = Model.Where(u => u.Role == "Lecturer") },
                    new { Title = "Trưởng Bộ môn (HOD)", Role = "HeadOfDepartment", Icon = "fa-user-tie", Data = Model.Where(u => u.Role == "HeadOfDepartment") }
                };
            }

            @foreach (var group in sections)
            {
                <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-2xl shadow-sm overflow-hidden">
                    <div class="px-6 py-5 border-b border-slate-100 dark:border-slate-800/60 bg-slate-50/50 dark:bg-slate-900/50 flex items-center justify-between sticky top-0 z-10 backdrop-blur-xl bg-slate-50/90 dark:bg-slate-900/90">
                        <h3 class="text-base font-bold text-gray-900 dark:text-white flex items-center gap-2">
                            <i class="fa-solid @group.Icon text-emerald-500 dark:text-emerald-400"></i>
                            @group.Title
                        </h3>
                        <span class="bg-emerald-100 dark:bg-emerald-500/20 text-emerald-700 dark:text-emerald-400 text-xs font-bold px-2.5 py-1 rounded-full">
                            @group.Data.Count() người
                        </span>
                    </div>
                    
                    <div class="overflow-x-auto">
                        <table class="w-full text-left text-sm text-slate-600 dark:text-slate-300">
                            <thead class="bg-slate-50 dark:bg-slate-950/50 text-xs uppercase font-semibold text-slate-500 dark:text-slate-400 border-b border-slate-200 dark:border-slate-800">
                                <tr>
                                    <th scope="col" class="px-6 py-4">Tài khoản</th>
                                    @if(group.Role == "Lecturer" || group.Role == "HeadOfDepartment") {
                                        <th scope="col" class="px-6 py-4">Bộ môn</th>
                                    }
                                    <th scope="col" class="px-6 py-4">Trạng thái</th>
                                    <th scope="col" class="px-6 py-4 text-center">Thao tác</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-slate-100 dark:divide-slate-800/60">
                                @if (!group.Data.Any())
                                {
                                    <tr>
                                        <td colspan="@(group.Role == "Lecturer" || group.Role == "HeadOfDepartment" ? 4 : 3)" class="px-6 py-12 text-center">
                                            <div class="flex flex-col items-center justify-center text-slate-400 dark:text-slate-500">
                                                <i class="fa-solid fa-user-slash text-4xl mb-3 opacity-20"></i>
                                                <p class="font-medium">Chưa có dữ liệu</p>
                                            </div>
                                        </td>
                                    </tr>
                                }
                                else
                                {
                                    foreach (var user in group.Data)
                                    {
                                        <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/30 transition-colors group">
                                            <td class="px-6 py-4">
                                                <div class="flex items-center gap-3">
                                                    <div class="w-10 h-10 rounded-full bg-gradient-to-br from-emerald-400 to-teal-500 flex items-center justify-center text-white font-bold text-sm shadow-sm">
                                                        @(user.LastName?.FirstOrDefault())@(user.FirstName?.FirstOrDefault())
                                                    </div>
                                                    <div>
                                                        <div class="font-bold text-gray-900 dark:text-slate-100 group-hover:text-emerald-600 dark:group-hover:text-emerald-400 transition-colors flex items-center gap-2">
                                                            @user.LastName @user.FirstName
                                                            <span class="text-[10px] text-slate-400 font-mono">#@user.Id</span>
                                                        </div>
                                                        <div class="text-xs text-slate-500 mt-0.5 flex items-center gap-1">
                                                            <i class="fa-solid fa-envelope text-[10px] opacity-70"></i>@user.Email
                                                        </div>
                                                </div>
                                            </td>
                                            
                                            @if(group.Role == "Lecturer" || group.Role == "HeadOfDepartment") {
                                                <td class="px-6 py-4">
                                                    @if (user.Department != null)
                                                    {
                                                        <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-blue-100 text-blue-800 dark:bg-blue-500/20 dark:text-blue-300">
                                                            @user.Department.Name
                                                        </span>
                                                    }
                                                    else
                                                    {
                                                        <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-slate-100 text-slate-500 dark:bg-slate-800 dark:text-slate-400">
                                                            Chưa có bộ môn
                                                        </span>
                                                    }
                                                </td>
                                            }

                                            <td class="px-6 py-4">
                                                @if (user.IsActive)
                                                {
                                                    <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-emerald-100 text-emerald-800 dark:bg-emerald-500/20 dark:text-emerald-300">
                                                        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
                                                        Hoạt động
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-rose-100 text-rose-800 dark:bg-rose-500/20 dark:text-rose-300">
                                                        <span class="w-1.5 h-1.5 rounded-full bg-rose-500"></span>
                                                        Đã khóa
                                                    </span>
                                                }
                                            </td>
                                            <td class="px-6 py-4">
                                                <div class="flex items-center justify-center gap-2">
                                                    <form asp-controller="Admin" asp-action="ToggleUserStatus" method="post" class="m-0">
                                                        <input type="hidden" name="id" value="@user.Id" />
                                                        <button type="submit" 
                                                            onclick="return confirm('Bạn có chắc chắn muốn @(user.IsActive ? "khóa" : "mở khóa") người dùng này?');"
                                                            class="w-8 h-8 flex items-center justify-center rounded-lg text-slate-400 hover:text-amber-600 hover:bg-amber-50 dark:hover:bg-amber-500/10 transition-colors"
                                                            title="@(user.IsActive ? "Khóa tài khoản" : "Mở khóa tài khoản")">
                                                            <i class="fa-solid @(user.IsActive ? "fa-lock" : "fa-unlock") text-sm"></i>
                                                        </button>
                                                    </form>
                                                    <form asp-controller="Admin" asp-action="DeleteUser" method="post" class="m-0">
                                                        <input type="hidden" name="id" value="@user.Id" />
                                                        <button type="submit" 
                                                            onclick="return confirm('Bạn có chắc chắn muốn xóa tài khoản này?');"
                                                            class="w-8 h-8 flex items-center justify-center rounded-lg text-slate-400 hover:text-red-600 hover:bg-red-50 dark:hover:bg-red-500/10 transition-colors"
                                                            title="Xóa tài khoản">
                                                            <i class="fa-solid fa-trash-can text-sm"></i>
                                                        </button>
                                                    </form>
                                                    <form asp-controller="Admin" asp-action="ResetPassword" method="post" class="m-0">
                                                        <input type="hidden" name="id" value="@user.Id" />
                                                        <button type="submit" 
                                                            onclick="return confirm('Bạn có chắc chắn muốn đặt lại mật khẩu về 123456 cho tài khoản này?');"
                                                            class="w-8 h-8 flex items-center justify-center rounded-lg text-slate-400 hover:text-blue-600 hover:bg-blue-50 dark:hover:bg-blue-500/10 transition-colors"
                                                            title="Đặt lại mật khẩu">
                                                            <i class="fa-solid fa-key text-sm"></i>
                                                        </button>
                                                    </form>
                                                    @if(group.Role == "Lecturer")
                                                    {
                                                        <button type="button" 
                                                            onclick="openUpdateLecturerDeptModal(@user.Id, @(user.DepartmentId?.ToString() ?? "null"))"
                                                            class="w-8 h-8 flex items-center justify-center rounded-lg text-slate-400 hover:text-emerald-600 hover:bg-emerald-50 dark:hover:bg-emerald-500/10 transition-colors"
                                                            title="Đổi Bộ môn">
                                                            <i class="fa-solid fa-pen text-sm"></i>
                                                        </button>
                                                    }
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
</div>

<!-- Modal Đổi bộ môn giảng viên -->
<div id="updateLecturerDeptModal" class="fixed inset-0 z-50 hidden bg-slate-900/50 backdrop-blur-sm flex items-center justify-center p-4">
    <div class="bg-white dark:bg-slate-900 rounded-2xl shadow-xl w-full max-w-md overflow-hidden flex flex-col">
        <div class="px-6 py-4 border-b border-slate-100 dark:border-slate-800 bg-slate-50 dark:bg-slate-900/50 flex justify-between items-center">
            <h3 class="text-base font-bold text-gray-900 dark:text-white">Cập nhật Bộ môn Giảng viên</h3>
            <button type="button" onclick="closeUpdateLecturerDeptModal()" class="text-slate-400 hover:text-slate-500">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>
        <form asp-controller="Admin" asp-action="UpdateLecturerDepartment" method="post" class="p-6">
            <input type="hidden" id="lecturerIdInput" name="userId" value="" />
            <div class="mb-5">
                <label class="block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-2">Bộ môn</label>
                <select id="lecturerDeptSelect" name="departmentId" class="w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-2.5 text-sm text-gray-900 dark:text-white outline-none focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/20 transition-all">
                    <option value="">-- Chưa có bộ môn --</option>
                    @if(ViewBag.Departments != null)
                    {
                        foreach(var dept in ViewBag.Departments)
                        {
                            <option value="@dept.Id">@dept.Name</option>
                        }
                    }
                </select>
            </div>
            <div class="flex gap-3 justify-end">
                <button type="button" onclick="closeUpdateLecturerDeptModal()" class="px-4 py-2 text-sm font-semibold text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-xl transition-all">
                    Hủy
                </button>
                <button type="submit" class="px-4 py-2 text-sm font-semibold text-white bg-emerald-600 hover:bg-emerald-700 rounded-xl transition-all shadow-sm shadow-emerald-500/30">
                    Lưu thay đổi
                </button>
            </div>
        </form>
    </div>
</div><!-- Single User Modal -->
<div id="singleUserModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-slate-900/40 dark:bg-slate-950/80 backdrop-blur-sm">
    <div class="bg-white dark:bg-slate-900 rounded-2xl shadow-xl w-full max-w-md overflow-hidden border border-slate-200 dark:border-slate-800">
        <div class="px-6 py-4 border-b border-slate-100 dark:border-slate-800 flex items-center justify-between">
            <h3 class="text-lg font-bold text-gray-900 dark:text-white">Tạo 1 Tài khoản</h3>
            <button onclick="closeSingleUserModal()" class="text-slate-400 hover:text-slate-600 dark:hover:text-slate-200 transition-colors">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>
        <form asp-controller="Admin" asp-action="CreateSingleUser" method="post">
            <div class="p-6 space-y-4">
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-xs font-semibold text-slate-500 dark:text-slate-400 mb-1.5 uppercase tracking-wider">Họ</label>
                        <input type="text" name="firstName" required class="w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-2 text-sm text-gray-900 dark:text-white outline-none focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/20" />
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-slate-500 dark:text-slate-400 mb-1.5 uppercase tracking-wider">Tên</label>
                        <input type="text" name="lastName" required class="w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-2 text-sm text-gray-900 dark:text-white outline-none focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/20" />
                    </div>
                </div>
                <div>
                    <label class="block text-xs font-semibold text-slate-500 dark:text-slate-400 mb-1.5 uppercase tracking-wider">Email</label>
                    <input type="email" name="email" required class="w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-2 text-sm text-gray-900 dark:text-white outline-none focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/20" />
                </div>
                <div>
                    <label class="block text-xs font-semibold text-slate-500 dark:text-slate-400 mb-1.5 uppercase tracking-wider">Mật khẩu</label>
                    <input type="text" name="password" value="123456" required class="w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-2 text-sm text-gray-900 dark:text-white outline-none focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/20" />
                </div>
                <div>
                    <label class="block text-xs font-semibold text-slate-500 dark:text-slate-400 mb-1.5 uppercase tracking-wider">Phân quyền</label>
                    <select name="role" id="singleUserRole" class="w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-2 text-sm text-gray-900 dark:text-white outline-none focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/20" onchange="toggleSingleUserDepartment()">
                        <option value="Student">Học sinh (Student)</option>
                        <option value="Lecturer">Giảng viên (Lecturer)</option>
                    </select>
                </div>
                <div id="singleUserDeptWrapper" style="display: none;">
                    <label class="block text-xs font-semibold text-slate-500 dark:text-slate-400 mb-1.5 uppercase tracking-wider">Bộ môn</label>
                    <select name="departmentId" class="w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-2 text-sm text-gray-900 dark:text-white outline-none focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/20">
                        <option value="">-- Vui lòng chọn --</option>
                        @if(ViewBag.Departments != null)
                        {
                            foreach(var dept in ViewBag.Departments)
                            {
                                <option value="@dept.Id">@dept.Name</option>
                            }
                        }
                    </select>
                </div>
            </div>
            <div class="px-6 py-4 border-t border-slate-100 dark:border-slate-800 bg-slate-50 dark:bg-slate-900/50 flex justify-end gap-3">
                <button type="button" onclick="closeSingleUserModal()" class="px-4 py-2 text-sm font-semibold text-slate-600 dark:text-slate-300 hover:bg-slate-200 dark:hover:bg-slate-700 rounded-xl transition-colors">
                    Hủy
                </button>
                <button type="submit" class="px-4 py-2 text-sm font-semibold text-white bg-emerald-600 hover:bg-emerald-700 rounded-xl transition-all shadow-sm shadow-emerald-500/30">
                    Tạo tài khoản
                </button>
            </div>
        </form>
    </div>
</div>

<script>
    function toggleDepartment() {
        var role = document.getElementById("roleSelect").value;
        var deptWrapper = document.getElementById("deptWrapper");
        if (role === "Lecturer") {
            deptWrapper.style.display = "block";
        } else {
            deptWrapper.style.display = "none";
        }
    }

    function openUpdateLecturerDeptModal(userId, deptId) {
        document.getElementById('lecturerIdInput').value = userId;
        document.getElementById('lecturerDeptSelect').value = deptId || "";
        document.getElementById('updateLecturerDeptModal').classList.remove('hidden');
    }

    function closeUpdateLecturerDeptModal() {
        document.getElementById('updateLecturerDeptModal').classList.add('hidden');
    }

    function toggleSingleUserDepartment() {
        var role = document.getElementById("singleUserRole").value;
        var deptWrapper = document.getElementById("singleUserDeptWrapper");
        if (role === "Lecturer") {
            deptWrapper.style.display = "block";
        } else {
            deptWrapper.style.display = "none";
        }
    }

    function openSingleUserModal() {
        document.getElementById('singleUserModal').classList.remove('hidden');
        document.getElementById('singleUserModal').classList.add('flex');
    }

    function closeSingleUserModal() {
        document.getElementById('singleUserModal').classList.add('hidden');
        document.getElementById('singleUserModal').classList.remove('flex');
    }
</script>

